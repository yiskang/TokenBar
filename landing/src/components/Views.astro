---
import { t, type Locale } from '../i18n/copy'
const { locale = 'en' } = Astro.props as { locale?: Locale }
const c = t(locale).views
const base = import.meta.env.BASE_URL
const slots = [
  { img: 'native/overview', accent: '--p-anthropic' },
  { img: 'native/models', accent: '--p-openai' },
  { img: 'native/monthly', accent: '--p-google' },
  { img: 'native/daily', accent: '--p-meta' },
  { img: 'native/hourly', accent: '--p-cursor' },
  { img: 'native/stats', accent: '--p-deepseek' },
  { img: 'native/agents', accent: '--p-mistral' },
]
const views = slots.map((s, i) => ({ ...s, ...c.items[i] }))
---

<section class="section" id="views">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">{c.eyebrow}</p>
      <h2>{c.h2}</h2>
      <p set:html={c.intro} />
    </div>

    <div class="grid">
      {views.map((v, i) => (
        <article class="card glass reveal" style={`--ac: var(${v.accent}); --rd: ${(i % 3) * 0.08}s;`}>
          <div class="frame">
            <img src={`${base}screenshots/${v.img}.png`} alt={c.altPrefix(v.name)} loading="lazy" />
          </div>
          <div class="meta">
            <h3><span class="tag" aria-hidden="true"></span>{v.name}</h3>
            <p>{v.desc}</p>
          </div>
        </article>
      ))}

      <article class="card glass wide reveal" style="--ac: var(--p-google);">
        <div class="frame">
          <img src={`${base}screenshots/native/contribution-3d.png`} alt={c.wideAlt} loading="lazy" />
        </div>
        <div class="meta">
          <h3><span class="tag" aria-hidden="true"></span>{c.wideTitle}</h3>
          <p set:html={c.wideDesc} />
        </div>
      </article>
    </div>
  </div>

  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label={c.lightboxLabel}>
    <button class="lb-close" id="lb-close" type="button" aria-label={c.lightboxClose}>×</button>
    <img id="lb-img" src="" alt="" />
  </div>
</section>

<script is:inline>
  (() => {
    const lb = document.getElementById('lightbox')
    const lbImg = document.getElementById('lb-img')
    const lbClose = document.getElementById('lb-close')
    if (!lb || !lbImg) return
    const open = (img) => {
      lbImg.src = img.currentSrc || img.src
      lbImg.alt = img.alt || ''
      lb.classList.add('open')
      document.body.style.overflow = 'hidden'
    }
    const close = () => { lb.classList.remove('open'); document.body.style.overflow = '' }
    document.querySelectorAll('.frame img').forEach((img) => {
      img.addEventListener('click', () => open(img))
    })
    lb.addEventListener('click', (e) => { if (e.target !== lbImg) close() })
    lbClose?.addEventListener('click', close)
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close() })
  })()
</script>

<style>
  .ilink { color: var(--accent-bright); border-bottom: 1px solid color-mix(in oklab, var(--accent) 40%, transparent); }
  .grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  /* hover feedback is glow + image zoom; transform stays owned by .reveal
     so the staggered float-in and the wide card's lean never fight it */
  .card { overflow: hidden; }
  .grid > .card:not(.wide):nth-of-type(7) { grid-column: 2; }
  .card:hover {
    border-color: color-mix(in oklab, var(--ac) 55%, var(--glass-edge));
    box-shadow: inset 0 1px 0 var(--glass-sheen),
      0 30px 60px -34px color-mix(in oklab, var(--ac) 60%, transparent);
  }
  .frame {
    position: relative; overflow: hidden;
    border-bottom: 1px solid var(--line);
    /* native shots are tall popover captures — a near-square window keeps the
       header + first card visible without making the grid towering */
    aspect-ratio: 1 / 1.05;
  }
  .frame::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 60%, color-mix(in oklab, var(--ac) 14%, transparent));
    pointer-events: none;
  }
  .frame img {
    width: 100%; height: 100%; object-fit: cover; object-position: top center;
    transition: transform .4s ease;
  }
  .card:hover .frame img { transform: scale(1.04); }
  .meta { padding: 18px 20px 22px; }
  .meta h3 { font-size: 19px; display: flex; align-items: center; gap: 10px; }
  .meta .tag { width: 9px; height: 9px; border-radius: 3px; background: var(--ac); box-shadow: 0 0 10px -1px var(--ac); }
  .meta p { color: var(--muted); font-size: 14.5px; margin-top: 8px; }

  .card.wide { grid-column: 1 / -1; display: grid; grid-template-columns: 1.4fr 1fr; margin-top: 10px; }
  .card.wide .frame { aspect-ratio: auto; border-bottom: none; border-right: 1px solid var(--line); }
  .card.wide .meta { align-self: center; padding: 32px 34px; }
  .card.wide .meta h3 { font-size: 24px; }
  .card.wide .meta p { font-size: 15.5px; }
  .card.wide strong { color: var(--ink-dim); }

  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
    .grid > .card:not(.wide):nth-of-type(7) { grid-column: auto; }
  }
  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
    .card.wide { grid-template-columns: 1fr; }
    .card.wide .frame { border-right: none; border-bottom: 1px solid var(--line); }
  }

  /* click-to-zoom lightbox */
  .frame img { cursor: zoom-in; }
  .lightbox {
    position: fixed; inset: 0; z-index: 100;
    display: none; place-items: center; padding: 4vmin;
    background: color-mix(in oklab, #05060a 78%, transparent);
    backdrop-filter: blur(10px);
    cursor: zoom-out;
    animation: lbFade .2s ease;
  }
  .lightbox.open { display: grid; }
  .lightbox img {
    max-width: 94vw; max-height: 90vh; width: auto; height: auto;
    border-radius: 14px; border: 1px solid var(--line-strong);
    box-shadow: 0 40px 100px -30px rgba(0, 0, 0, 0.8);
    cursor: default;
  }
  .lb-close {
    position: fixed; top: 22px; right: 26px;
    width: 42px; height: 42px; border-radius: 50%;
    border: 1px solid var(--line-strong); background: color-mix(in oklab, var(--panel) 80%, transparent);
    color: var(--ink); font-size: 24px; line-height: 1; cursor: pointer;
    transition: transform .15s, border-color .15s;
  }
  .lb-close:hover { transform: scale(1.08); border-color: var(--accent); color: var(--accent-bright); }
  @keyframes lbFade { from { opacity: 0; } to { opacity: 1; } }
</style>
